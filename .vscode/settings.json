{
  "search.exclude": {
    "**/dependencies-viewer.json": true,
    "**/node_modules": true,
    "**/dist": true,
    "**/*.log": true
  },
  "files.exclude": {
    "**/node_modules": true
    // "**/*.js.map": true,
    // "**/dist": true
  },
  "files.associations": {
    "*.ts": "typescript"
  },
  "editor.minimap.enabled": false,
  "editor.formatOnSave": true,
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit",
    "source.organizeImports": "explicit"
  },
  "emmet.includeLanguages": {
    "typescript": "html"
  },
  "explorer.fileNesting.enabled": true,
  "explorer.fileNesting.expand": false,
  "explorer.fileNesting.patterns": {
    "*.js": "${capture}.js.map, ${capture}.min.js, ${capture}.d.ts, ${capture}.scss, ${capture}.html, ${capture}.css,, ${capture}.json",
    "*.ts": "${capture}.js.map, ${capture}.min.js, ${capture}.d.ts, ${capture}.scss, ${capture}.html, ${capture}.md",
    "webpack.common.cjs": "webpack.*.cjs"
  },
  "js/ts.preferences.includePackageJsonAutoImports": "on",
  "js/ts.suggest.autoImports": true,
  "js/ts.suggest.paths": true,
  "js/ts.updateImportsOnFileMove.enabled": "always",
  "js/ts.preferences.importModuleSpecifier": "relative",
  "js/ts.format.enabled": false,
  "eslint.validate": ["typescript"],
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.tabSize": 2
  },
  "[scss]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "cSpell.customDictionaries": {
    "custom-dictionary-workspace": {
      "name": "custom-dictionary-workspace",
      "path": "${workspaceFolder:flayground}/.cspell/custom-dictionary-workspace.txt",
      "addWords": true,
      "scope": "workspace"
    }
  }
}
