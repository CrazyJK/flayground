# Google Gemini API 키 (없으면 Gemini 모델 비활성화)
GEMINI_API_KEY=

# GitHub Personal Access Token (없으면 GitHub 모델 비활성화)
GITHUB_TOKEN=

# 로컬 Ollama OpenAI 호환 엔드포인트 (없으면 로컬 모델 비활성화)
LOCAL_AI_ENDPOINT=http://127.0.0.1:11434/v1
# 로컬 제공자용 더미 API 키 (Ollama는 무시, 비워두면 'ollama')
LOCAL_AI_API_KEY=ollama

# MCP 서버 설정 (선택)
MCP_SERVER_NAME=nexus-server
MCP_SERVER_VERSION=1.0.0

# HTTP 서버 포트 (선택, 기본값: 3002)
PORT=3002
