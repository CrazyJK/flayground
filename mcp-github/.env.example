# GitHub Personal Access Token (https://github.com/settings/tokens)
# Fine-grained 또는 Classic 모두 가능, 별도 scope 불필요
GITHUB_TOKEN=your_github_token_here

# 사용할 모델 (선택, 기본값: gpt-4o-mini)
# 전체 목록: https://github.com/marketplace/models
# 예: gpt-4o, gpt-4o-mini, Meta-Llama-3.1-405B-Instruct, claude-3-5-sonnet
GITHUB_MODELS_MODEL=gpt-4o-mini

# HTTP 서버 포트 (기본값: 3001)
PORT=3001

# MCP Server Configuration
MCP_SERVER_NAME=github-models-server
MCP_SERVER_VERSION=1.0.0
