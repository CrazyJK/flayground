{
  "name": "flay-web-backend",
  "version": "1.0.0",
  "description": "Flay Web Backend Node.js Server",
  "repository": "https://github.com/CrazyJK/flayground",
  "author": "kamoru",
  "license": "MIT",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
